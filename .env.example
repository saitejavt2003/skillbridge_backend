PORT=5000
# Exact deployed frontend origin. Use a comma-separated list only if needed.
FRONTEND_URL=https://your-vercel-production-domain.vercel.app
DEFAULT_BATCH_ID=1

DATABASE_URL=postgresql://user:password@host:5432/database
# Set DB_SSL=false only when using a local PostgreSQL database that does not support SSL.

DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=30000
